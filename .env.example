# ============================================================
# LearnOS Dashboard — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# Get these from: Supabase Dashboard → Project Settings → API
#
# DO NOT commit .env.local — it is listed in .gitignore
# ============================================================

# Your Supabase project URL (e.g. https://xyzabcdef.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anon/public key (older projects use this format)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase publishable key (newer projects use this format)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
